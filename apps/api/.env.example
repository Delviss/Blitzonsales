DATABASE_URL=postgresql://blitz:blitzdev@localhost:5432/blitzonsales
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
REDIS_URL=redis://localhost:6379
PORT=3001
# Mandatory TOTP 2FA for admin_gf/backoffice (Phase 5 hardening). Keep "true" for any
# real deployment. Set to "false" only for temporary local/demo access via plain
# hashed-password login while 2FA enrollment isn't practical yet.
REQUIRE_2FA=true

# --- Joules / SWA API (Wave 3, I-08/I-09) ---
# Base URL of the Joules RESTful API v2. Defaults to the documented endpoint.
JOULES_BASE_URL=https://service.billig-will-ich.de/service/v2
# Auth mode: "apikey" or "basic". Leave everything below unset until BlitzON
# supplies a test-tenant credential — the sync then reports "nicht_konfiguriert"
# and the Excel import (I-12) stays the interim source. (I-08 is externally
# blocked on this credential; the host may also need allow-listing.)
JOULES_AUTH_MODE=
JOULES_API_KEY=
JOULES_BASIC_USER=
JOULES_BASIC_PASS=
# Opt-in scheduled sync. Off by default; only arms when a credential is present.
JOULES_SYNC_ENABLED=false
JOULES_SYNC_INTERVAL_MS=3600000
